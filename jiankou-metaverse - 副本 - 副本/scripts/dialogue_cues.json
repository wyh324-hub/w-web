{
  "scene1.mp3": {
    "duration": 28.92,
    "dialogueAt": 18.8,
    "segments": [
      {
        "start": 0.0,
        "end": 5.12,
        "text": "1943年秋,你以要財商販的身份第一次來到建國村"
      },
      {
        "start": 5.38,
        "end": 7.94,
        "text": "上級交代,到關地妙旁的"
      },
      {
        "start": 8.2,
        "end": 10.5,
        "text": "不興商號,雜貨部與代號"
      },
      {
        "start": 10.76,
        "end": 12.8,
        "text": "鴻梅的地下黨員街頭"
      },
      {
        "start": 13.06,
        "end": 14.6,
        "text": "去回一份緊急情報"
      },
      {
        "start": 14.86,
        "end": 16.38,
        "text": "你推開商號的誤門"
      },
      {
        "start": 16.64,
        "end": 18.68,
        "text": "貴臺後的長貴看了你一眼"
      },
      {
        "start": 18.94,
        "end": 20.74,
        "text": "不僅不慢的問,客觀"
      },
      {
        "start": 21.0,
        "end": 22.78,
        "text": "你是要買紅紙還是白紙"
      },
      {
        "start": 23.04,
        "end": 25.34,
        "text": "你記得上級交代過街頭案號"
      },
      {
        "start": 25.6,
        "end": 28.92,
        "text": "對方問,買什麼紙去回答特定的下半句"
      }
    ]
  },
  "scene3.mp3": {
    "duration": 29.2,
    "dialogueAt": 27.32,
    "segments": [
      {
        "start": 0.0,
        "end": 3.24,
        "text": "1941年12月,泰平洋戰爭爆發"
      },
      {
        "start": 3.24,
        "end": 7.0,
        "text": "嚴峻大學英吉教授林麥克夫夫身陷陷近"
      },
      {
        "start": 7.0,
        "end": 9.48,
        "text": "上集只是你務必接應他們安全"
      },
      {
        "start": 9.48,
        "end": 11.28,
        "text": "封國妙封山骨香道"
      },
      {
        "start": 11.28,
        "end": 13.28,
        "text": "前往平息抗日根據地"
      },
      {
        "start": 13.28,
        "end": 16.28,
        "text": "你推著獨輪車感到約定的老懷術下"
      },
      {
        "start": 16.28,
        "end": 19.2,
        "text": "看到一位帶原礦眼睛的外國男子"
      },
      {
        "start": 19.2,
        "end": 21.56,
        "text": "和一位女士神色不安的戰爭"
      },
      {
        "start": 21.56,
        "end": 23.0,
        "text": "你上前低聲說"
      },
      {
        "start": 23.0,
        "end": 25.48,
        "text": "教授,我是來接您上山的"
      },
      {
        "start": 25.48,
        "end": 27.32,
        "text": "林麥克吃衣的看著你"
      },
      {
        "start": 27.32,
        "end": 29.2,
        "text": "How can I trust you?"
      }
    ]
  },
  "sujing/scene1.mp3": {
    "duration": 27.4,
    "dialogueAt": 15.76,
    "segments": [
      {
        "start": 0.0,
        "end": 4.88,
        "text": "1943年深蹤,你以,俗靜的身份被拍到劍枸村。"
      },
      {
        "start": 4.88,
        "end": 11.92,
        "text": "上集安排的演護身份是農貨家新過門的媳婦,與房東的兒子,住子假半夫妻。"
      },
      {
        "start": 11.92,
        "end": 15.76,
        "text": "第一天早晨,你跟著婆婆一起做飯。"
      },
      {
        "start": 15.76,
        "end": 21.36,
        "text": "照台前,婆婆一邊天才一邊隨口問,歸女,你老家是哪兒的。"
      },
      {
        "start": 21.36,
        "end": 23.72,
        "text": "你的真實身份絕不能暴露。"
      },
      {
        "start": 23.72,
        "end": 27.4,
        "text": "上集只交代過一句,組織上會安排好一切。"
      }
    ]
  },
  "guxiangdao/scene2.mp3": {
    "duration": 21.9,
    "dialogueAt": 14.24,
    "segments": [
      {
        "start": 0.0,
        "end": 4.38,
        "text": "走到半山腰的茶蓬附近,你看到前方射了卡。"
      },
      {
        "start": 4.38,
        "end": 15.86,
        "text": "幾個尾軍正在盤查過往行人,一個跨著步槍的士兵,朝你招手,推車的過來,你的獨輪車底曾藏著藥品,上層撲著山火和乾草。"
      },
      {
        "start": 15.86,
        "end": 21.9,
        "text": "如果不能蒙混過關,藥品沒收還是小事,身份暴露則是滅頂之災。"
      }
    ]
  },
  "chuxin/scene2.mp3": {
    "duration": 21.4,
    "dialogueAt": 15.44,
    "segments": [
      {
        "start": 0.0,
        "end": 6.08,
        "text": "廣場旁的初心庭內一塊石碑技術著第三任戰長梁波列式的世紀"
      },
      {
        "start": 6.08,
        "end": 9.72,
        "text": "你讀著悲文 梁波1947年9月"
      },
      {
        "start": 9.72,
        "end": 15.44,
        "text": "執行街頭任務返回途中預敵 突為食音勇氣聲 年僅37歲"
      },
      {
        "start": 15.44,
        "end": 21.4,
        "text": "一位老人站在庭子旁 見你駐族 緩緩開口 你是來看梁戰長的"
      }
    ]
  }
}